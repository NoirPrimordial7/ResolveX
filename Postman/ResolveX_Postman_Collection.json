                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Creates a new customer account. Public registration should create customer role only.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Customer\",\n  \"email\": \"postman.customer{{$timestamp}}@resolvex.com\",\n  \"password\": \"Customer@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 200 or 201 or already handled', function () { pm.expect([200,201,400,409]).to.include(pm.response.code); });",
                  "if ([200,201].includes(pm.response.code)) { const data = pm.response.json(); pm.test('Registered user has email', () => pm.expect(JSON.stringify(data)).to.include('@resolvex.com')); }"
                ]
              }
            }
          ]
        },
