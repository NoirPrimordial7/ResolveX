              ]
            },
            "description": "Verifies role-based access control."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Customer blocked from admin dashboard', function () { pm.expect([401,403]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
